# GTI Router — configuration example
#
# Copy this file to /boot/router.yaml before first boot.
# On first boot the service will copy it to /etc/gti-router/router.yaml (mode 0600).
#
# Secrets (AWS keys, Supabase service-role key) must be provided via
# environment variables.  Use the ${VAR_NAME} syntax to expand them.
# NEVER put plaintext credentials in this file (NFR9).
#
# Path resolution order:
#   1. /etc/gti-router/router.yaml
#   2. /boot/router.yaml
#   3. $ROUTER_CONFIG  (development / CI override)

# ── Cameras ───────────────────────────────────────────────────────────────────
#
# Each entry represents one video source.  You may have multiple cameras.
# camera_id must be unique within this router.
#
cameras:
  # ── Example 1: IP camera via RTSP ──────────────────────────────────────────
  - camera_id: cam-front
    input_type: rtsp_ip
    rtsp_url: "rtsp://admin:password@192.168.1.100:554/stream1"
    orientation:
      azimuth: 45.0        # compass heading (0–360°, 0 = North)
      tilt: -15.0          # vertical angle (-90 to +90°)
      fov_h: 90.0          # horizontal field-of-view (degrees)
      mount_height_m: 6.0  # installation height above ground (metres)
    gps:                   # optional — static installation coordinates
      lat: 19.432608
      lon: -99.133209
      altitude_m: 2250.0

  # ── Example 2: capture card (analogue / DJI HDMI via V4L2) ─────────────────
  # Uncomment and adapt for Router Pro with a capture card.
  # - camera_id: cam-dji
  #   input_type: capture_card
  #   device: /dev/video0
  #   orientation:
  #     azimuth: 180.0
  #     tilt: -20.0
  #     fov_h: 60.0
  #     mount_height_m: 4.0

# ── HLS segmentation ──────────────────────────────────────────────────────────
hls:
  segment_duration: 4       # seconds per .ts segment (2–8)
  output_dir: /var/lib/gti-router/hls

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# Secrets MUST come from environment variables.
aws:
  bucket: gti-video-segments
  region: us-east-1
  access_key_id: "${AWS_ACCESS_KEY_ID}"         # set in /etc/gti-router/env
  secret_access_key: "${AWS_SECRET_ACCESS_KEY}" # set in /etc/gti-router/env
  prefix: ""   # optional extra path prefix inside the bucket

# ── Supabase ──────────────────────────────────────────────────────────────────
supabase:
  url: "https://your-project.supabase.co"
  service_role_key: "${SUPABASE_SERVICE_ROLE_KEY}"  # set in /etc/gti-router/env

# ── Device identity ───────────────────────────────────────────────────────────
device:
  serial_number: "GTR-BASE-000001"  # unique hardware serial (printed on label / QR)
  name: "Router Norte Parcela 3"
  gateway_id: null                  # UUID of the linked Gateway (null = standalone)
  sku: base                         # "base" (RPi4) or "pro" (RPi5)

# ── Health reporting ──────────────────────────────────────────────────────────
health:
  report_interval_s: 60         # seconds between health reports (10–300)
  cpu_alert_threshold: 80.0     # % CPU usage that triggers WARNING
  temp_alert_threshold: 75.0    # °C sustained temperature alert
  temp_critical_threshold: 80.0 # °C threshold for throttling WARNING
  disk_alert_threshold: 80.0    # % disk usage alert

# ── Licensing / hardware limits ───────────────────────────────────────────────
licensing:
  max_cameras: 1   # hardware / licence ceiling; override to 2–4 for Pro nodes
